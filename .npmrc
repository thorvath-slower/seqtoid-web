engine-strict = true
# bug-#003 (Node 16 -> 20 -> 24 / npm 8.5.5 -> 10 -> 11): npm 10/11 enforce peer deps
# strictly at install time, which the legacy frontend tree trips on. This preserves the
# previously-working resolution.
#
# CZID-19 cleared the @sentry/react@5 (peer react 15/16/17) blocker by upgrading to
# @sentry/react@8 (peer react 16/17/18). Removing legacy-peer-deps still trips two OTHER
# pre-existing conflicts that must be cleared first, tracked as follow-ups:
#   1. @types/react@17 (dev) vs @testing-library/react@16 (peer @types/react ^18||^19) —
#      needs @types/react 17 -> 18 (pairs with @types/react-dom, already 18) + a TS type pass.
#   2. d3-selection@1 vs d3-transition@3 (peer d3-selection "2 - 3") — needs d3-selection 1 -> 3,
#      a breaking bump touching the heatmap/tree visualizations.
legacy-peer-deps = true