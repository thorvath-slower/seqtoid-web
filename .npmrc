engine-strict = true
# bug-#003 (Node 16 -> 20 -> 24 / npm 8.5.5 -> 10 -> 11): npm 10/11 enforce peer deps
# strictly at install time, which the legacy frontend tree trips on (e.g. @sentry/react@5
# declares peer react 15/16/17 while the app is on react 18). This preserves the
# previously-working resolution. Removing it is a separate frontend dependency-cleanup
# task (upgrade @sentry/react to a react-18-compatible major).
legacy-peer-deps = true