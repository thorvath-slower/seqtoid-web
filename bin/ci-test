#!/usr/bin/env bash
# Canonical test steps for seqtoid-web on MySQL (Version 2, jsims-faithful).
# run identically by the local harness (bin/ci-local, via docker-compose.ci.yml).
# Expects: Ruby 3.3.6, a reachable MySQL (DB_HOST/DB_USERNAME/DB_PASSWORD),
# Redis, RAILS_ENV=test, dummy AWS_* env.
set -euo pipefail

echo "::group::System deps"
# python3-dev + build-essential are required to compile biom-format's C
# extension (Python.h); without them the pip step fails. nodejs for asset bits,
# default-mysql-client for the mysql CLI, default-libmysqlclient-dev for the
# mysql2 native gem build.
apt-get update && apt-get install -y python3-pip python3-dev build-essential nodejs default-mysql-client default-libmysqlclient-dev
pip3 config set global.break-system-packages true
echo "::endgroup::"

echo "::group::Ruby deps"
gem install bundler:"$(tail -1 Gemfile.lock | tr -d ' ')" --no-document 2>/dev/null || gem install bundler --no-document
bundle config path vendor/bundle
bundle install --jobs 4 --retry 3
echo "::endgroup::"

echo "::group::Python deps"
pip3 install --upgrade pip
pip3 install "cython<3.0.0"
pip3 install "pyyaml==5.4.1" --no-build-isolation
pip3 install -r requirements.txt
echo "::endgroup::"

echo "::group::Dummy static assets (ruby tests don't need real bundles)"
mkdir -p app/assets/dist
for f in main.bundle.min.css main.bundle.min.js vendors.bundle.min.css vendors.bundle.min.js; do echo foo > "app/assets/dist/$f"; done
echo "::endgroup::"

# Parallelism auto-scales to the box: CI's ubuntu-latest is 2-core, dev boxes have more.
# parallel_tests shards the suite across N processes, each owning its own test DB
# (idseq_test, idseq_test2, … — see config/database.yml + TEST_ENV_NUMBER) inside the
# single MySQL service container. Falls back to a serial run if parallel_tests is absent
# so local runs never hard-break.
PARALLEL_N="$(command -v nproc >/dev/null 2>&1 && nproc || echo 2)"

if bundle exec parallel_test --version >/dev/null 2>&1; then
  echo "::group::Create + load ${PARALLEL_N} parallel MySQL schemas"
  # parallel:drop first so reloads start clean (MySQL force:cascade drops trip FK
  # constraints when tables already exist); idempotent on fresh DBs. load_schema mirrors
  # today's db:schema:load (loads schema.rb, NOT migrations).
  bundle exec rake "parallel:drop[${PARALLEL_N}]" \
                   "parallel:create[${PARALLEL_N}]" \
                   "parallel:load_schema[${PARALLEL_N}]"
  echo "::endgroup::"

  echo "::group::RSpec (parallel x${PARALLEL_N})"
  # parallel_rspec prints per-process summaries then one final combined
  # "N examples, M failures" line to stdout — the regression gate reads the last one.
  SAMPLES_BUCKET_NAME=idseq-samples-development \
    bundle exec parallel_rspec -n "${PARALLEL_N}"
  echo "::endgroup::"
else
  echo "::group::Create + load MySQL schema (serial fallback)"
  # db:drop first so reloads start clean (MySQL force:cascade drops trip FK constraints
  # when tables already exist); idempotent on a fresh DB.
  bundle exec bin/rails db:drop db:create db:schema:load
  echo "::endgroup::"

  echo "::group::RSpec (serial fallback)"
  SAMPLES_BUCKET_NAME=idseq-samples-development bundle exec rspec
  echo "::endgroup::"
fi
