#!/bin/bash
# NOTE: We push all created tags to the Docker repo, but only the commit, branch, and latest tags matter.
# Cache and compose are noise.
set -euo pipefail

export REPO="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/idseq-web"

BRANCH="$1"
BRANCH_CLEANED=$(echo $BRANCH | sed 's/\//-/g')
COMMIT="$2"
BRANCH_TAG=$REPO:"branch-$BRANCH_CLEANED"
CACHE_TAG="$REPO:cache"
COMMIT_TAG=$REPO:"sha-$COMMIT"
COMPOSE_TAG="$REPO:compose"
LATEST_TAG="$REPO:latest"

echo "Branch $BRANCH"
echo "Commit $COMMIT"
echo "Repo   $REPO"
echo '--'

# Try to pull the latest image for this branch, otherwise pull latest image for caching
if ! ( docker pull $BRANCH_TAG && docker tag $BRANCH_TAG $CACHE_TAG ); then
    # If we fail to fetch the latest image, continue the build without a cache image.
    (docker pull $LATEST_TAG && docker tag $LATEST_TAG $CACHE_TAG) || true
fi

# Hash of the frontend asset source + webpack/babel config, passed as a build-arg
# so the Dockerfile's asset-build layer cache-busts on any frontend change
# (CZID-380). Without this, --cache-from can reuse a stale `build-img` layer and
# ship an old bundle even though the source changed. Uses the git-tracked content
# (index blobs) so the hash is deterministic and matches what gets committed.
SRC_HASH=$(git ls-files -s app/assets webpack.config.common.js webpack.config.prod.js .babelrc | git hash-object --stdin)
echo "Asset SRC_HASH $SRC_HASH"

docker build -t $COMPOSE_TAG --cache-from $CACHE_TAG --build-arg GIT_COMMIT=${COMMIT} --build-arg SRC_HASH=${SRC_HASH} .

if [ "$BRANCH" == "main" ]; then
    docker tag $COMPOSE_TAG $LATEST_TAG
fi
docker tag $COMPOSE_TAG $COMMIT_TAG
docker tag $COMPOSE_TAG $BRANCH_TAG
